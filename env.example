# ---------------------------------------------------------------------------
# Blobbie Playground — environment variables
# Copy to .env (and .env.local for Next.js public vars) and fill in.
# ---------------------------------------------------------------------------

# Chain config: 56 = BNB Smart Chain mainnet, 97 = BNB Testnet
NEXT_PUBLIC_CHAIN_ID=97

# Contract / wallet addresses. Leave empty to run in Beta Mock Mode.
NEXT_PUBLIC_BLOBBIE_TOKEN_ADDRESS=
NEXT_PUBLIC_DAILY_DRAW_CONTRACT_ADDRESS=
NEXT_PUBLIC_JACKPOT_CONTRACT_ADDRESS=
NEXT_PUBLIC_OPERATIONAL_WALLET_ADDRESS=
NEXT_PUBLIC_BURN_ADDRESS=

# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Feature flags
# When true (or when token/contract addresses are missing) the app runs in
# Beta Mock Mode: no real transactions are ever submitted.
NEXT_PUBLIC_ENABLE_MOCK_MODE=true
NEXT_PUBLIC_ENABLE_TICKET_PURCHASE=true

# Mock $BLOBBIE price in USD used when no oracle is configured.
# 1 Ticket = $1 USD equivalent in $BLOBBIE (never hardcoded as 1 token).
NEXT_PUBLIC_MOCK_BLOBBIE_PRICE_USD=0.0025

# Optional: public site URL for SEO/metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Server-only
# ---------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blobbie?schema=public

# Comma-separated admin wallet address(es) allowed into /admin
ADMIN_WALLET_ADDRESS=

# Secret used to sign wallet session JWTs (use a long random string)
JWT_SECRET=change-me-in-production-with-a-long-random-string

# ---------------------------------------------------------------------------
# Airdrop Social Tasks (X + Telegram). When configured, tasks are verified via
# the official APIs. When missing/unavailable, tasks are never auto-confirmed.
# ---------------------------------------------------------------------------

ENABLE_X_VERIFICATION=true
ENABLE_TELEGRAM_VERIFICATION=true

# X (Twitter) OAuth 2.0 (Authorization Code + PKCE) — https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/social/x/callback
X_BEARER_TOKEN=
X_BLOBBIE_USERNAME=xBlobbie
X_BLOBBIE_USER_ID=
X_API_BASE_URL=https://api.x.com/2

# Telegram: create a bot via @BotFather, add it as admin to your group/channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_URL=
# Secret for the bot deep-link webhook (set the same value when calling
# setWebhook with secret_token). Optional but recommended.
TELEGRAM_WEBHOOK_SECRET=

# Social task rewards (points)
AIRDROP_X_FOLLOW_POINTS=100
AIRDROP_TELEGRAM_JOIN_POINTS=75
AIRDROP_BONUS_SOCIAL_POINTS=50

# Optional 32+ char key to encrypt OAuth tokens at rest (defaults to a
# JWT_SECRET-derived key when unset).
SOCIAL_ENCRYPTION_KEY=
